TELEGRAM_BOT_TOKEN=put_your_bot_token_here
BOT_NAME=OgreScanBot
DATABASE_PATH=ogrescanbot.sqlite3
# Use this on Render with a free external Postgres DB so calls survive redeploys.
# Example: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=
MIN_MULTIPLE_FOR_HIT=2.0
ENABLE_RUGCHECK=true
ENABLE_PUMP_METADATA=true
ENABLE_GECKOTERMINAL_ATH=true
ENABLE_SOLANA_RPC=true
# Free public default works for supply/top-holder checks, but can rate-limit.
# For best accuracy/reliability, use a free RPC URL from Helius, QuickNode, Alchemy, Triton, etc.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Optional heavy exact holder-count check. Use only with a good RPC URL.
ENABLE_SOLANA_HOLDER_COUNT=false
CALL_UPDATE_INTERVAL_SECONDS=180
CALL_UPDATE_LIMIT=150
KEEP_ALIVE_INTERVAL_SECONDS=600
# Optional. Defaults to WEBHOOK_URL/healthz when WEBHOOK_URL is set.
# Leave blank on Render unless you want to ping a different URL.
KEEP_ALIVE_URL=
# Exact ticker aliases are checked before Dexscreener search.
# Format: TICKER=contract,TICKER2=contract2
TICKER_ALIASES=OGRE=5RAZMWd9RiKfodLPQ73cFk4CMoJzTUsATUoRdDThpump

# Easiest free persistence without Postgres:
# Create a private Telegram backup channel, add the bot as admin, then post /setbackup in that channel.
# Optional: set BACKUP_CHAT_ID manually if you already know the numeric channel id.
BACKUP_CHAT_ID=
BACKUP_CHAT_ID_FILE=backup_chat_id.txt
BACKUP_INTERVAL_SECONDS=60
RESTORE_BACKUP_ON_START=true

# local polling is easiest on your PC.
# webhook is best for free web hosting.
RUN_MODE=polling
WEBHOOK_URL=https://your-free-host.example.com
WEBHOOK_PATH=/telegram/webhook
HOST=0.0.0.0
PORT=8080
